{
  "name": "@dhinesh-se/angular-components",
  "version": "0.1.0",
  "description": "Reusable enterprise Angular building blocks: permission directive, workflow timeline, smart table, dynamic forms, and query builder.",
  "license": "MIT",
  "author": "Dhinesh SE",
  "homepage": "https://github.com/dhinesh-se/Angular_components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhinesh-se/Angular_components.git"
  },
  "bugs": {
    "url": "https://github.com/dhinesh-se/Angular_components/issues"
  },
  "keywords": [
    "angular",
    "components",
    "enterprise",
    "permissions",
    "workflow",
    "table",
    "forms",
    "query-builder"
  ],
  "private": false,
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rm -rf dist out-tsc",
    "build": "ng build enterprise-components",
    "test": "ng test enterprise-components --watch=false",
    "lint": "ng lint enterprise-components",
    "pack:dry-run": "npm pack ./dist/enterprise-components --dry-run",
    "publish:dry-run": "npm publish ./dist/enterprise-components --dry-run --access public",
    "publish:public": "npm publish ./dist/enterprise-components --access public"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/forms": ">=17.0.0",
    "rxjs": ">=7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "ng-packagr": "^18.2.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.0",
    "typescript": "~5.5.0",
    "zone.js": "^0.14.10"
  }
}
